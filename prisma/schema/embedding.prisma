
model Resource {
  id         String   @id @default(cuid()) 
  content    String   
  createdAt  DateTime @default(now()) 
  updatedAt  DateTime @default(now()) 

  embeddings Embedding[] // Define relation to Embedding model

  @@index([createdAt]) // Optional: index on createdAt for faster queries
  @@index([updatedAt]) // Optional: index on updatedAt for faster queries
}


model Embedding {
  id         String   @id @default(cuid()) 
  resourceId String
  content    String   
  embedding  Unsupported("vector(1536)")

  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  // @@index([embedding], name: "embeddingIndex" ) // Custom index for vector (handle manually)
}